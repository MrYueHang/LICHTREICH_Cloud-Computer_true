{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.lichtreich.info/schemas/workflow.schema.json",
  "title": "LICHTREICH Workflow-Metastruktur",
  "description": "Maschinenlesbare Definition eines Workflows der Betriebskette (Eingang → Analyse → Interview → Briefe/Dokumente → Akte/Ausgang). Gemeinsame Quelle für öffentliche FAQ, interne Betriebsdoku und n8n-JSON-Bibliotheken. Ein Workflow gilt erst als 'live' (grün), wenn Happy Paths UND Fehlerfälle bestehen.",
  "type": "object",
  "required": ["slug", "title", "purpose", "steps", "status", "owner"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Eindeutiger Kleinbuchstaben-Slug, z.B. 'bob-briefweg'."
    },
    "title": { "type": "string", "description": "Menschenlesbarer Titel." },
    "purpose": { "type": "string", "description": "Wozu der Workflow dient (1 Satz)." },
    "inputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Akzeptierte Eingaben (z.B. PDF, Foto, Scan, Hinweise/Kommentare/Strategie)."
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["briefkasten", "orchestra", "rag", "mandat", "n8n", "setup", "board", "society", "consult", "ingest", "tickets", "mcp", "api"]
      },
      "description": "Beteiligte Subdomains/Dienste."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["upload", "ocr", "classify", "strategy", "interview", "draft", "finalize", "compare", "ingest", "embed", "route", "notify"]
      },
      "description": "Verarbeitungsschritte in Reihenfolge."
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Erzeugte Artefakte (z.B. Analyse, Dossier, Entwurf, Final, Akte)."
    },
    "tests": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Happy Paths + Fehlerfälle, die grün sein müssen."
    },
    "known_gaps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ehrlich dokumentierte Bruchstellen (Alpha/Beta)."
    },
    "owner": {
      "type": "string",
      "description": "Verantwortlicher Dienst (Head-of-Board)."
    },
    "status": {
      "type": "string",
      "enum": ["alpha", "pilot", "beta", "live"],
      "description": "Reifegrad. 'live' erst nach QA-Doppel-Review."
    },
    "dialogue_point": {
      "type": "object",
      "description": "Dialog-Punkt-Muster: KI schlägt vor, User bestätigt/kommentiert, KI führt aus.",
      "additionalProperties": false,
      "properties": {
        "state": { "type": "string", "enum": ["vorschlag", "bestaetigt", "ausgefuehrt"] },
        "never_guess": { "type": "boolean", "default": true },
        "on_unclear": { "type": "string", "enum": ["rueckfragen"], "default": "rueckfragen" }
      }
    }
  }
}
