# === AI Studio (automatisch injiziert) ===
# GEMINI_API_KEY: Gemini AI. AI Studio injiziert zur Laufzeit aus den User-Secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL: Host-URL des Applets (Cloud Run). Für Self-Links, OAuth-Callbacks, API-Endpoints.
APP_URL="MY_APP_URL"

# === LICHTREICH Source-of-Truth (read) ===
# Projekt-/Kontext-API, aus der die Reiter/Head-of-Board gerendert werden.
LICHTREICH_API_BASE="https://api.lichtreich.info/api/v1"

# === Provider-Broker (cheap-first, spart Anthropic-Token) ===
# Reihenfolge: groq -> openai(4o-mini) -> gemini. Nur setzen, was genutzt wird.
GROQ_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""

# === Warteliste (Debug: Hero-Form hat noch kein Backend) ===
# Ziel für Waitlist-Mails: entweder Neon-Tabelle ODER n8n-Webhook. EINES wählen.
WAITLIST_WEBHOOK_URL=""       # z.B. https://n8n.lichtreich.info/webhook/warteliste
DATABASE_URL=""               # Neon, falls direkt in Tabelle 'warteliste'

# === RAG / Ingest (Task 4 — Endpoint noch zu bestätigen, health=404) ===
RAG_INGEST_URL=""             # produktiver Ingest-Endpoint
RAG_INGEST_TOKEN=""

